# PassPal Environment Configuration
# This file contains environment-specific settings for the PassPal application
# Copy this file to .env and modify the values as needed

# API Configuration
PAL_API_BASE_URL=https://api.chukyo-passpal.app/v1

# Feature Flags (Development)
FEATURE_NEW_ASSIGNMENT_PARSER=true
FEATURE_BIOMETRIC_AUTH=true
FEATURE_OFFLINE_MODE=false
FEATURE_EXPERIMENTAL=true

# Debug Settings (Development only)
DEBUG_SHOW_LOGS=true
DEBUG_MOCK_DATA=false
DEBUG_NETWORK_LOGGING=true
DEBUG_PERFORMANCE_MONITORING=false

# Note: In production, these values will be overridden by Firebase Remote Config
# The .env file is primarily for development and testing purposes
